800851,8_23_851,"Но пока мне рот"
800851,8_50_851,"раздаваться"
800851,8_14_851,"вороненый зрачок"
800851,8_41_851,"изгнанья"
800851,8_3_851,"жил у моря,"
800851,8_43_851,"связкам"
800852,8_0_852,"Я входил вместо"
800852,8_3_852,"жил у моря,"
800852,8_26_852,"дикого зверя в клетку,"
800852,8_7_852,"Бросил страну,"
800852,8_38_852,"сухую воду"
800852,8_28_852,"в бараке,"
800852,8_37_852,"черной толью гумна"
800852,8_29_852,"играл в рулетку,"
