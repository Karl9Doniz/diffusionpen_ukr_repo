200124,2_2_124,"Что мог монах"
200124,2_29_124,"клятвой обещал;"
200124,2_30_124,"и улыбки"
200124,2_50_124,"его питает"
200124,2_31_124,"не всегда"
200124,2_32_124,"малые ошибки"
200124,2_33_124,"иногда,"
200124,2_36_124,"не названье"
200124,2_34_124,"от страданья,"
200124,2_3_124,"И жить, как"
200124,2_35_124,"счастья сотворен,"
200124,2_49_124,"яд другим,"
200124,2_37_124,"чем сон!..."
200124,2_39_124,"хладныи"
200124,2_51_124,"язвительным своим"
200124,2_38_124,"теплои"
200124,2_4_124,"Что поцелуи"
200124,2_28_124,"не лицемерить"
200124,2_19_124,"Умерших, но"
200124,2_27_124,"не испытал,"
200124,2_40_124,"каждыи миг"
200124,2_8_124,"Что время лечит"
200124,2_16_124,"Желаннои цели"
200124,2_15_124,"И ум, как прежде"
200124,2_17_124,"И сердце"
200124,2_18_124,"Хранит в себе"
200124,2_7_124,"Они прощают"
200124,2_1_124,"Хоть сам того"
200124,2_12_124,"Но вере"
200124,2_20_124,"И тени чувств,"
200124,2_13_124,"опыт"
200124,2_6_124,"Что ближних"
200124,2_22_124,"И то,"
200124,2_23_124,"было б"
200124,2_24_124,"Его живит"
200124,2_5_124,"Людей коварны"
200124,2_25_124,"Огнем"
200124,2_26_124,"обещаю верить"
200124,2_21_124,"Его ничто"
200124,2_41_124,"безотрадныи"
200124,2_14_124,"Противуречит"
200124,2_0_124,"Я верю,"
200124,2_46_124,"каких уж нет;"
200124,2_42_124,"не достиг;"
200124,2_43_124,"полно сожалении"
200124,2_47_124,"не испугает,"
200125,2_13_125,"опыт"
200125,2_22_125,"И то,"
200125,2_33_125,"иногда"
200125,2_46_125,"каких уж нет;"
200125,2_6_125,"Что ближних"
200125,2_4_125,"Что поцелуи"
200125,2_21_125,"Его ничто"
200125,2_32_125,"малые ошибки"
200125,2_35_125,"счастья сотворен,"
200125,2_36_125,"не названье"
200125,2_20_125,"И тени чувств,"
200125,2_1_125,"Хоть сам того"
200125,2_49_125,"яд другим;"
200125,2_42_125,"не достиг;"
200125,2_34_125,"от страданья,"
200125,2_23_125,"было бы"
200125,2_24_125,"Его живит,"
200125,2_37_125,"чем сон!..."
200125,2_9_125,"Что мир для"
200125,2_28_125,"не лицемерить"
200125,2_12_125,"Но вере"
200125,2_51_125,"язвительным своим"
200125,2_43_125,"полно сожалений"
200125,2_29_125,"клятвой обещал;"
200125,2_27_125,"не испытал,"
200125,2_2_125,"Что мог монах"
200125,2_26_125,"обещаю верить,"
200125,2_47_125,"не испугает,"
200125,2_30_125,"и улыбки"
200125,2_25_125,"Огнем"
200125,2_5_125,"Людей коварны"
200125,2_50_125,"его питает"
200125,2_31_125,"не всегда,"
200125,2_11_125,"И жизнь поболее"
200125,2_19_125,"Умерших, но"
200125,2_41_125,"безотрадный,"
200125,2_38_125,"теплои"
200125,2_17_125,"И сердце"
200125,2_14_125,"Противуречит"
200125,2_8_125,"Что время лечит"
200125,2_10_125,"Что добродетель"
200125,2_3_125,"И жить, как"
200125,2_39_125,"хладный"
200125,2_48_125,"что"
200125,2_16_125,"Желанной цели"
200125,2_40_125,"каждый миг,"
200125,2_7_125,"Они прощают"
200125,2_0_125,"Я верю"
200125,2_18_125,"Хранит в себе"
