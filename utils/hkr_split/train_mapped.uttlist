500305,5_17_305,"Ты стала вновь"
500305,5_47_305,"испепеленные года"
500305,5_43_305,"могучей и свободной"
500305,5_44_305,"моя"
500305,5_16_305,"Там мать поет,"
500305,5_45_305,"навсегда"
500305,5_46_305,"памяти народной"
500305,5_15_305,"И там, где сердце"
500305,5_7_305,"Далеко с моря"
500305,5_49_305,"до полярных льдов,"
500305,5_4_305,"И маяки сквозь"
500305,5_13_305,"Где елей"
500305,5_12_305,"Автомобил"
500305,5_5_305,"Путь указуя"
500305,5_6_305,"На их огонь,"
500305,5_11_305,"И по изрытому"
500305,5_42_305,"качая колыбель"
500305,5_8_305,"Где танк"
500305,5_48_305,"юных поколений,"
500305,5_41_305,"нылоот разлуки,"
500305,5_35_305,"мирный трактор,"
500305,5_3_305,"Опять полны"
500305,5_27_305,"нанесенные войной,"
500305,5_10_305,"Где выл пожар"
500305,5_25_305,"Встают громады"
500305,5_28_305,"и русские поляны"
500305,5_29_305,"студеной тишиной"
500305,5_24_305,"Как памятники"
500305,5_2_305,"Страна моя,"
500305,5_30_305,"мрак приморской ночи,"
500305,5_31_305,"моряку, горят"
500305,5_18_305,"Страна"
500305,5_32_305,"как в дружеские очи,"
500305,5_21_305,"Войной"
500305,5_34_305,"гремел —"
500305,5_20_305,"В сокровищнице"
500305,5_36_305,"благоухает сад,"
500305,5_37_305,"когда-то тракту"
500305,5_1_305,"Жестокои"
500305,5_38_305,"легкие летят"
500305,5_39_305,"искалеченные руки"
500305,5_19_305,"Но живы"
500305,5_33_305,"моряки глядят."
500305,5_9_305,"там ныне"
500305,5_26_305,"и залечила раны,"
500305,5_0_305,"Прошло пять лет,"
500306,5_40_306,"зеленеет ель,"
500306,5_33_306,"моряки глядят."
500306,5_43_306,"могучей и свободной,"
500306,5_14_306,"Взывали к мщенью."
500306,5_21_306,"Войной"
500306,5_34_306,"гремел —"
500306,5_35_306,"мирный трактор,"
500306,5_20_306,"В сокровищнице"
500306,5_36_306,"благюухает сад,"
500306,5_47_306,"испепеленные года"
500306,5_37_306,"когда-то тракту"
500306,5_15_306,"И там, где сердце"
